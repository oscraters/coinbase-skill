#!/usr/bin/env bash
set -euo pipefail

BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${COINBASE_SKILL_CONFIG_FILE:-${OPENCLAW_SKILL_CONFIG_FILE:-}}"
SKILL_KEY="${COINBASE_SKILL_KEY:-coinbase-cdp-bash}"

if [[ -n "${CONFIG_FILE}" && -f "${CONFIG_FILE}" ]]; then
  export COINBASE_SKILL_CONFIG_FILE="${CONFIG_FILE}"
  export COINBASE_SKILL_KEY="${SKILL_KEY}"

  while IFS='=' read -r key value; do
    case "${key}" in
      COINBASE_API_BASE_URL)
        : "${COINBASE_API_BASE_URL:=${value}}"
        export COINBASE_API_BASE_URL
        ;;
      COINBASE_WALLET_API_BASE_URL)
        : "${COINBASE_WALLET_API_BASE_URL:=${value}}"
        export COINBASE_WALLET_API_BASE_URL
        ;;
      COINBASE_DEFAULT_NETWORK)
        : "${COINBASE_DEFAULT_NETWORK:=${value}}"
        export COINBASE_DEFAULT_NETWORK
        ;;
      COINBASE_ALLOWED_HOSTS)
        : "${COINBASE_ALLOWED_HOSTS:=${value}}"
        export COINBASE_ALLOWED_HOSTS
        ;;
      COINBASE_REQUEST_TIMEOUT_SECONDS)
        : "${COINBASE_REQUEST_TIMEOUT_SECONDS:=${value}}"
        export COINBASE_REQUEST_TIMEOUT_SECONDS
        ;;
      COINBASE_ENVIRONMENT)
        : "${COINBASE_ENVIRONMENT:=${value}}"
        export COINBASE_ENVIRONMENT
        ;;
      COINBASE_WALLET_API_VERSION)
        : "${COINBASE_WALLET_API_VERSION:=${value}}"
        export COINBASE_WALLET_API_VERSION
        ;;
    esac
  done < <(
    jq -r --arg skillKey "${SKILL_KEY}" '
      (.skills.entries[$skillKey] // .[$skillKey] // {}) as $entry
      | [
          "COINBASE_API_BASE_URL=\($entry.config.apiBaseUrl // "")",
          "COINBASE_WALLET_API_BASE_URL=\($entry.config.walletApiBaseUrl // "")",
          "COINBASE_DEFAULT_NETWORK=\($entry.config.defaultNetwork // "")",
          "COINBASE_ALLOWED_HOSTS=\(
            if ($entry.config.allowedHosts | type) == "array" then
              ($entry.config.allowedHosts | join(","))
            else
              ($entry.config.allowedHosts // "")
            end
          )",
          "COINBASE_REQUEST_TIMEOUT_SECONDS=\($entry.config.requestTimeoutSeconds // "")",
          "COINBASE_ENVIRONMENT=\($entry.config.environment // "")",
          "COINBASE_WALLET_API_VERSION=\($entry.config.walletApiVersion // "")"
        ]
      | .[]
      | select(. | endswith("=") | not)
    ' "${CONFIG_FILE}"
  )
fi

exec "${BASE_DIR}/coinbase-cli" "$@"
